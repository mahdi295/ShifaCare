PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/shifacare

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d
COOKIE_EXPIRE=30

# YOUR FRONTEND URL (change port if Vite uses 5174)
CLIENT_URL=http://localhost:5173

# FIX: For local dev, use your ngrok URL here — NOT localhost
# SSLCommerz calls this URL from their server, so localhost won't work
# Run: ngrok http 5000
# Then copy the https URL e.g: https://abc123.ngrok-free.app
BACKEND_URL=https://YOUR_NGROK_URL_HERE

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# SSLCommerz — use SANDBOX credentials for local testing
# Get from: https://developer.sslcommerz.com/registration/
SSL_STORE_ID=your_sandbox_store_id
SSL_STORE_PASS=your_sandbox_store_password
# Keep this false for local/sandbox testing
SSL_IS_LIVE=false
