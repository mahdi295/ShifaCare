# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_string_32_chars_minimum
JWT_EXPIRE=30d
COOKIE_EXPIRE=30

# ── URLs ──────────────────────────────────────────────────────────────────────
# CRITICAL: These two values are used for CORS and payment redirects.
# LOCAL development:
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
#
# PRODUCTION (example — replace with your actual deployed URLs):
# CLIENT_URL=https://shifacare.vercel.app
# BACKEND_URL=https://shifacare-backend.onrender.com
#
# NOTE: Do NOT include trailing slashes.
# NOTE: BACKEND_URL must be publicly reachable by SSLCommerz servers (not localhost).
#       In production this should be your Render backend URL.

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SSLCommerz ────────────────────────────────────────────────────────────────
# Get credentials from: https://developer.sslcommerz.com/
SSL_STORE_ID=your_store_id
SSL_STORE_PASS=your_store_password
# Set to false for sandbox testing, true only in live production
SSL_IS_LIVE=false

# ── SMTP (optional — for password reset emails) ───────────────────────────────
# If not configured, password reset links will be returned in the API response (dev only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youremail@gmail.com
# For Gmail: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password
SMTP_FROM="ShifaCare" <noreply@shifacare.com>

# ── AI Chatbot (Groq) ─────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com/keys
# NEVER commit your real key or paste it in chat/screenshots.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
